{
  "name": "mikian-photos",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "next lint",
    "prisma:generate": "prisma generate",
    "prisma:push": "dotenv -e .env.local -- prisma db push",
    "prisma:push:prod": "dotenv -e .env.production -- prisma db push",
    "prisma:migrate": "dotenv -e .env.local -- prisma migrate deploy",
    "prisma:seed": "dotenv -e .env.local -- prisma db seed",
    "prisma:seed:prod": "dotenv -e .env.production -- prisma db seed",
    "prisma:studio": "dotenv -e .env.local -- prisma studio"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1054.0",
    "@aws-sdk/s3-request-presigner": "^3.1054.0",
    "@paypal/react-paypal-js": "^9.2.0",
    "@prisma/client": "^5.22.0",
    "exifr": "^7.1.3",
    "jose": "^5.10.0",
    "next": "14.2.35",
    "next-auth": "^4.24.14",
    "react": "^18",
    "react-dom": "^18",
    "sharp": "^0.33.5",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "dotenv-cli": "^11.0.0",
    "prisma": "^5.22.0",
    "tsx": "^4.22.3",
    "typescript": "^5"
  }
}
