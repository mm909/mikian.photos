// Mikian.Photos — production schema for v0.2 photos pipeline.
// One event (Lighthouse Half 2026) per row to start; we can support
// more events without schema changes.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Vercel Postgres provides both pooled (POSTGRES_URL) + non-pooled
  // (POSTGRES_URL_NON_POOLING). Prisma uses non-pooled for migrations,
  // pooled for the runtime client. directUrl handles that split.
  url       = env("POSTGRES_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model Event {
  // `id` doubles as the public URL slug (e.g. "lighthouse-half-2026") — it is
  // the FK target everywhere (Photo.eventId, PhotoFace.eventId,
  // FaceAssignment.eventId, Order.eventIdCovered, the Rekognition collection
  // name). No @default: new events get an explicit, slugified id.
  id            String         @id
  name          String
  date          DateTime
  city          String
  org           String
  // Owner-editable bundle price in whole cents (e.g. 2500 = $25.00). Stored
  // as an Int to avoid float drift; nullable so events created before this
  // field fall back to the static `prices.bundle` default at read time.
  bundlePriceCents Int?

  // --- v2 multi-event config (all defaulted → additive `db push`) ---------
  // Lifecycle: "draft" (not yet live) | "published" (live) | "archived"
  // (kept out of the default picker without deleting). String-enum to match
  // the project convention (roles, PhotoBib.source); validated in code via
  // src/lib/eventConfig.ts.
  status          String   @default("published")
  // Visibility: "public" (listed + searchable) | "secure-link" (unlisted,
  // reachable only with secretLinkToken) | "account-only" (must be signed in).
  // Enforced by src/lib/eventAccess.ts in BOTH the page layout and the APIs.
  accessMode      String   @default("public")
  // Random token gating "secure-link" events. Set only when accessMode is
  // "secure-link"; null otherwise. @unique allows many NULLs in Postgres.
  secretLinkToken String?  @unique
  // Free events skip PayPal entirely (it rejects $0). A separate flag — NOT
  // bundlePriceCents=0 — so a $0 *paid* misconfig can't silently hit PayPal.
  // Defaults false so the existing (paid) Lighthouse row stays paid on push.
  isFree          Boolean  @default(false)
  // Per-event detection toggles. Gate runDetection() on top of the env-level
  // *Configured() checks (run only if eventFlag && envConfigured).
  ocrEnabled      Boolean  @default(true)
  faceRecEnabled  Boolean  @default(true)
  // Optional per-event OCR override (OcrSettings JSON); null → DEFAULT_OCR_SETTINGS.
  ocrSettings     Json?

  // --- v2.2 camp color groups -------------------------------------------
  // When on, detection samples each detected person's shirt color (the torso
  // region directly below their face) and snaps it to the nearest anchor in
  // DEFAULT_CAMP_PALETTE — producing a per-person color group ("blue",
  // "lavender", …) with no manual setup. Default false so existing race events
  // are untouched; camp events default it on (see defaultsForType). Requires
  // face recognition (color is sampled relative to face boxes).
  colorGroupEnabled Boolean @default(false)
  // Optional rename map for the auto-detected groups, e.g. { "blue": "Blue
  // Jays" }. Null → use the palette's built-in label per key. Lets an owner
  // relabel groups later without re-running detection (editor deferred).
  colorGroupLabels  Json?
  // Optional external "browse all photos" destination (e.g. a shared Google
  // Photos album). When set, a camp event's "Browse all photos" button links
  // out to this URL instead of opening the in-app browse gallery — the album's
  // own unlisted-link sharing is the access boundary. Null → in-app browse.
  externalBrowseUrl String?

  // --- v2.1 general platform ---------------------------------------------
  // Event type drives the runner UX + capability defaults (see
  // eventCapabilities() in src/lib/eventConfig.ts). "race" | "gallery" to start;
  // the model is data-driven so more types are a config addition, not a schema
  // change. The live Lighthouse row defaults to "race" (correct).
  type            String   @default("race")
  // The event's owner: manages its settings, photographer access, and orders.
  // Defaults to the platform owner (Mikian); clients can own events later with
  // no schema change. Per-event admin = platform owner OR this owner.
  ownerId         String?
  owner           Photographer? @relation("EventOwner", fields: [ownerId], references: [id])

  photographers Photographer[] @relation("PrimaryEvent")
  // Per-event photographer access list — who may upload into this event. A
  // plain "photographer" needs a row here; owner/race_director bypass it.
  eventPhotographers EventPhotographer[]
  photos        Photo[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt @default(now())
}

/// Per-event photographer access grant. A join table (not an array column) so
/// Postgres can FK-validate it, index the per-upload "is X allowed on Y" check,
/// and cascade-clean on delete — matching the relational style of PhotoBib /
/// PhotoFace / FaceAssignment.
///
/// Semantics (enforced in code): owner + race_director may upload to ANY event
/// implicitly; a plain "photographer" may upload to event X iff a row exists
/// here. The upload picker lists accessible events; the real gate is the
/// membership check in the sign route.
model EventPhotographer {
  id             String   @id @default(cuid())
  eventId        String
  photographerId String
  // Future per-event granularity; null = the binary "may upload" grant.
  role           String?
  // Audit: who added this membership (actor id or email).
  addedBy        String?
  createdAt      DateTime @default(now())

  event        Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  photographer Photographer @relation("EventAccess", fields: [photographerId], references: [id], onDelete: Cascade)

  @@unique([eventId, photographerId])
  @@index([photographerId])
  @@index([eventId])
}

/// Photographer is misnamed — it's really the User table (every signed-in
/// person gets a row, runners included). Keeping the name to avoid a sweeping
/// rename right before launch; treat it as User in your head.
model Photographer {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  // populated by NextAuth on first sign-in; nullable for seeded test rows
  googleSubject  String?  @unique
  // Soft default for the upload event picker (NOT an access grant — access is
  // EventPhotographer only). Pre-selects this event if the user can upload to it.
  primaryEventId String?
  primaryEvent   Event?   @relation("PrimaryEvent", fields: [primaryEventId], references: [id])
  // Events this user owns (v2.1 per-event ownership). See Event.ownerId.
  ownedEvents    Event[]  @relation("EventOwner")
  // Per-event upload access grants (v2 multi-event). See EventPhotographer.
  eventAccess    EventPhotographer[] @relation("EventAccess")
  photos         Photo[]
  // Roles authoritative — see src/lib/permissions.ts for the type. Valid
  // values: "user" | "photographer" | "owner" (v2.1: race_director removed,
  // runner renamed to user). A user can hold multiple roles; owner implies all.
  // Per-event ownership (Event.ownerId) + EventPhotographer carry the rest.
  roles          String[] @default(["user"])
  // Legacy mirror of `roles.includes("owner")` — kept for back-compat with
  // existing API routes that branch on `session.isAdmin` or `pg.isAdmin`.
  // Set on every write that touches `roles`; new code should prefer `roles`
  // directly via the permissions helpers.
  isAdmin        Boolean  @default(false)
  createdAt      DateTime @default(now())
  // Orders this user placed (linked at capture time via session email
  // match). Guest orders — buyer wasn't signed in at checkout — carry a
  // null userId and are reached only via the tokenized email link until
  // the buyer signs in later with a matching email.
  orders         Order[]  @relation("UserOrders")
}

model Photo {
  id             String    @id @default(cuid())
  eventId        String
  photographerId String
  mile           Int?
  gpsLat         Float?
  gpsLng         Float?
  takenAt        DateTime?
  // R2 object keys (NOT full URLs — server signs on demand)
  r2OriginalKey  String
  r2PreviewKey   String
  // photographer or admin can soft-hide
  hidden         Boolean   @default(false)
  // basic moderation log
  hiddenBy       String?
  hiddenAt       DateTime?
  // Client-computed SHA-256 of the original file bytes. Used by the upload
  // sign route to detect duplicate uploads (same image being ingested
  // twice). null on rows created before this field existed.
  fingerprint    String?
  // Timestamp of the last successful Rekognition IndexFaces call. null when
  // never indexed. Used by the rerun-faces endpoint and the upload finalize
  // path to skip already-processed photos unless `force` is passed.
  facesIndexedAt DateTime?
  createdAt      DateTime  @default(now())

  event        Event        @relation(fields: [eventId], references: [id])
  photographer Photographer @relation(fields: [photographerId], references: [id])
  bibs         PhotoBib[]
  faces        PhotoFace[]
  colorGroups  PhotoColorGroup[]

  @@index([eventId, hidden])
  @@index([photographerId])
  @@index([fingerprint])
}

/// One row per face detected in a photo.
///
/// Two ID fields with different semantics:
///   - `rekognitionFaceId` — globally unique id Rekognition assigns when we
///     IndexFaces. Stable for the lifetime of the entry in Rekognition's
///     collection; we delete it via DeleteFaces when the photo is removed.
///     Nullable so manual-source rows (no Rekognition entry) can exist.
///   - `faceClusterId` — soft grouping of "this is the same runner across
///     multiple photos." For MVP we set it equal to rekognitionFaceId at
///     write time and refine later via Rekognition's SearchFaces (face-to-
///     face) clustering pass. Nullable for the same reason.
///
/// `eventId` is denormalized off Photo so we can issue collection-scoped
/// DeleteFaces calls without joining. (One Rekognition collection per event.)
///
/// Coverage screen aggregates by faceClusterId to count "photos per face."
/// Runner face search hits SearchFacesByImage → matches FaceIds → joins
/// back through this table to photoIds.
model PhotoFace {
  id                 String   @id @default(cuid())
  photoId            String
  eventId            String
  rekognitionFaceId  String?  @unique
  faceClusterId      String?
  confidence         Float    @default(0.0)
  // Bounding box in normalized [0,1] coordinates (Rekognition's native
  // format). Multiply by the preview image's width/height to draw.
  x0                 Float
  y0                 Float
  x1                 Float
  y1                 Float
  // The bib this face is geometrically linked to *within this photo* — the
  // bib whose box sits directly below this face (a runner's number is on the
  // torso, under the face). Computed at ingest from the face + bib boxes by
  // linkFacesToBibsForPhoto(); see src/lib/faceBibMatch.ts. Null when no bib
  // box is close enough below the face (or bib OCR has no box yet). This is
  // what makes per-runner face assignment robust in multi-runner frames.
  bib                Int?
  // The camp "team color" for THIS person — the torso region directly below the
  // face, sampled at detection time and snapped to the nearest DEFAULT_CAMP_
  // PALETTE anchor (see src/lib/colorGroups.ts). Null when color grouping is off
  // for the event, the photo has no usable torso region, or the sample was too
  // ambiguous. A face cluster's group is the statistical mode of this field over
  // the cluster — that's what the camp face search uses to find teammates.
  colorGroup         String?
  // Raw sampled torso color as "#rrggbb" — debugging + future re-clustering.
  colorHex           String?
  // "rekognition" | "facenet" | "manual" — same idea as PhotoBib.source.
  source             String   @default("rekognition")
  createdAt          DateTime @default(now())

  photo Photo @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@index([faceClusterId])
  @@index([photoId])
  @@index([eventId])
  @@index([eventId, bib])
  @@index([eventId, colorGroup])
}

/// One row per (photo, bib) tag. Same photo can carry several bibs (multiple
/// runners in frame); same bib can appear on many photos. `source` lets us
/// re-run detection or revoke a specific provider's results later.
model PhotoBib {
  id         String   @id @default(cuid())
  photoId    String
  bib        Int
  confidence Float    @default(1.0)
  source     String   @default("manual") // "manual" | "ocr-tesseract" | "ocr-rekognition" | "user-tag"
  // Bounding box of the detected bib number, normalized [0,1] (same space as
  // PhotoFace). Populated by OCR (Tesseract/Rekognition); null for manual /
  // user-tag rows and for rows created before box capture existed. Used to
  // link a face to the bib directly below it — see src/lib/faceBibMatch.ts.
  x0         Float?
  y0         Float?
  x1         Float?
  y1         Float?
  createdAt  DateTime @default(now())

  photo Photo @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@unique([photoId, bib])
  @@index([bib])
}

/// One row per (photo, colorGroup) — the distinct camp color groups visible in
/// a photo. The parallel to PhotoBib/PhotoFace: a photo can carry several color
/// groups (multiple teams in frame), and a group appears across many photos.
///
/// Denormalized from the per-face PhotoFace.colorGroup so "every photo that
/// contains the Blue group" is a single indexed lookup — that's the expansion
/// the camp face search does after inferring a runner's own group. `count` is
/// how many people of that group were detected in the photo.
///
/// `eventId` is denormalized off Photo so the lookup is event-scoped without a
/// join (mirrors PhotoFace.eventId). Rebuilt wholesale per photo on each
/// detection pass (delete + re-create), so it stays in sync with the faces.
model PhotoColorGroup {
  id         String   @id @default(cuid())
  photoId    String
  eventId    String
  colorGroup String
  count      Int      @default(1)
  confidence Float    @default(1.0)
  source     String   @default("auto") // "auto" | "manual"
  createdAt  DateTime @default(now())

  photo Photo @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@unique([photoId, colorGroup])
  @@index([eventId, colorGroup])
  @@index([photoId])
}

/// Human-confirmed face for a runner (bib) in an event.
///
/// The app can GUESS a runner's face from geometry + clustering
/// (computeFaceAssignments / autoConfirmClusterForBib), but that guess is
/// ephemeral and only auto-applies when a bib maps to exactly one cluster.
/// This table records a face an OWNER explicitly confirmed on the runner
/// profile page — which then becomes AUTHORITATIVE:
///   - the runner profile shows bib-tagged ∪ face-cluster photos
///   - the roster photo count is the same union
///   - the public find-photos flow auto-expands by this cluster and skips
///     the "Is this you?" prompt (we already confirmed it by hand)
///
/// One confirmed face per (event, bib). Re-confirming upserts; clearing
/// deletes the row (falls back to the heuristic guess).
model FaceAssignment {
  id            String   @id @default(cuid())
  eventId       String
  bib           Int
  faceClusterId String
  /// Who confirmed it (actor id or email) — audit only, nullable.
  assignedBy    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([eventId, bib])
  @@index([eventId])
  @@index([eventId, faceClusterId])
}

/// Order is what the buyer paid for. One row per successful PayPal capture.
///
/// Identifiers:
///   - `id` — internal cuid, used in JWT claims + relations
///   - `orderNumber` — human-readable sequential int, displayed as
///     "MK-000123" (see src/lib/orderId.ts). Stable, never changes.
///   - `paypalCaptureId` — the PayPal capture identifier; carried for
///     reconciliation with PayPal's dashboard / refund flows.
///
/// Entitlement:
///   - `photoIds[]` — snapshot of every photo this order grants access to.
///     Computed server-side at capture time (e.g. "every visible photo in
///     event X" for a bundle). Stored explicitly so future re-mint or
///     re-issue is straightforward.
///   - `downloadToken` — JWT that carries `{ orderId, photoIds }`. The
///     download API verifies this token before signing a hi-res URL.
///
/// Buyer linkage:
///   - `email` is always set (from PayPal payer if not signed-in).
///   - `userId` is set when the buyer was signed in at checkout — that
///     order shows up automatically on /runner. A guest order's userId is
///     null until we wire a back-fill flow ("claim this order" when an
///     existing user signs in later with the same email).
model Order {
  id              String    @id @default(cuid())
  orderNumber     Int       @unique @default(autoincrement())
  // Buyer linkage (always have email; userId set only when signed-in at capture)
  email           String
  userId          String?
  user            Photographer? @relation("UserOrders", fields: [userId], references: [id])
  // Bundle vs single — v0.2 ships bundle only. Single will add photoIdCovered.
  kind            String    @default("bundle")
  amount          Float
  // Event the order covers (always set for bundle; carries the scope used to
  // expand photoIds at capture time)
  eventIdCovered  String?
  photoIdCovered  String?
  // Entitlement snapshot — what the buyer can download (every id here is
  // also claimable via the downloadToken JWT)
  photoIds        String[]
  // PayPal capture id — for reconciliation with PayPal's dashboard, refunds.
  // Unique so re-capture attempts can't double-insert.
  paypalCaptureId String?   @unique
  // 30-day JWT carrying { orderId }. Minted on capture, kept on the row
  // so we can re-send the receipt email later without re-minting.
  // NO @unique — the encoded JWT is variable-length text and an index on
  // it busts the Postgres btree row-size limit; we never query by token
  // anyway (downloads supply it in the URL and we verify by signature).
  downloadToken   String?
  paidAt          DateTime  @default(now())
  createdAt       DateTime  @default(now())

  // --- Owner ops: receipt-email tracking + refunds ------------------
  // Receipt delivery outcome, recorded by createPaidOrder() and the owner
  // "resend receipt" action. emailError holds the last failure (e.g.
  // Resend "domain not verified") so the Orders admin can surface why a
  // buyer never got their email.
  emailSentAt     DateTime?
  emailError      String?
  // Refund state. refundedAt + refundId are set when an owner issues a
  // PayPal refund via /api/admin/orders/[orderNumber]/refund.
  refundedAt      DateTime?
  refundId        String?

  @@index([email])
  @@index([userId])
  @@index([eventIdCovered])
}

// Generic fixed-window rate-limit counter. One row per (key, windowStart);
// the key encodes the rule + subject (e.g. "facesearch:burst:ip:1.2.3.4").
// Incremented atomically via INSERT ... ON CONFLICT in src/lib/rateLimit.ts so
// concurrent requests can't undercount. Used to throttle expensive public
// endpoints (face search) without an external store (no Redis in this stack).
// Expired rows are swept opportunistically; `expiresAt` indexes that sweep.
model RateLimit {
  key         String
  windowStart DateTime
  count       Int      @default(0)
  expiresAt   DateTime

  @@id([key, windowStart])
  @@index([expiresAt])
}
