// Mikian.Photos — production schema for v0.2 photos pipeline.
// One event (Lighthouse Half 2026) per row to start; we can support
// more events without schema changes.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Vercel Postgres provides both pooled (POSTGRES_URL) + non-pooled
  // (POSTGRES_URL_NON_POOLING). Prisma uses non-pooled for migrations,
  // pooled for the runtime client. directUrl handles that split.
  url       = env("POSTGRES_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model Event {
  id            String         @id
  name          String
  date          DateTime
  city          String
  org           String
  photographers Photographer[]
  photos        Photo[]
  createdAt     DateTime       @default(now())
}

/// Photographer is misnamed — it's really the User table (every signed-in
/// person gets a row, runners included). Keeping the name to avoid a sweeping
/// rename right before launch; treat it as User in your head.
model Photographer {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  // populated by NextAuth on first sign-in; nullable for seeded test rows
  googleSubject  String?  @unique
  // many-to-many with events is overkill for MVP; we attach via Photo.eventId only
  primaryEventId String?
  primaryEvent   Event?   @relation(fields: [primaryEventId], references: [id])
  photos         Photo[]
  // Roles authoritative — see src/lib/permissions.ts for the type. Valid
  // values: "runner" | "photographer" | "race_director" | "owner". A user
  // can hold multiple roles; owner implies everything below.
  roles          String[] @default(["runner"])
  // Legacy mirror of `roles.includes("owner")` — kept for back-compat with
  // existing API routes that branch on `session.isAdmin` or `pg.isAdmin`.
  // Set on every write that touches `roles`; new code should prefer `roles`
  // directly via the permissions helpers.
  isAdmin        Boolean  @default(false)
  createdAt      DateTime @default(now())
  // Orders this user placed (linked at capture time via session email
  // match). Guest orders — buyer wasn't signed in at checkout — carry a
  // null userId and are reached only via the tokenized email link until
  // the buyer signs in later with a matching email.
  orders         Order[]  @relation("UserOrders")
}

model Photo {
  id             String    @id @default(cuid())
  eventId        String
  photographerId String
  mile           Int?
  gpsLat         Float?
  gpsLng         Float?
  takenAt        DateTime?
  // R2 object keys (NOT full URLs — server signs on demand)
  r2OriginalKey  String
  r2PreviewKey   String
  // photographer or admin can soft-hide
  hidden         Boolean   @default(false)
  // basic moderation log
  hiddenBy       String?
  hiddenAt       DateTime?
  // Client-computed SHA-256 of the original file bytes. Used by the upload
  // sign route to detect duplicate uploads (same image being ingested
  // twice). null on rows created before this field existed.
  fingerprint    String?
  // Timestamp of the last successful Rekognition IndexFaces call. null when
  // never indexed. Used by the rerun-faces endpoint and the upload finalize
  // path to skip already-processed photos unless `force` is passed.
  facesIndexedAt DateTime?
  createdAt      DateTime  @default(now())

  event        Event        @relation(fields: [eventId], references: [id])
  photographer Photographer @relation(fields: [photographerId], references: [id])
  bibs         PhotoBib[]
  faces        PhotoFace[]

  @@index([eventId, hidden])
  @@index([photographerId])
  @@index([fingerprint])
}

/// One row per face detected in a photo.
///
/// Two ID fields with different semantics:
///   - `rekognitionFaceId` — globally unique id Rekognition assigns when we
///     IndexFaces. Stable for the lifetime of the entry in Rekognition's
///     collection; we delete it via DeleteFaces when the photo is removed.
///     Nullable so manual-source rows (no Rekognition entry) can exist.
///   - `faceClusterId` — soft grouping of "this is the same runner across
///     multiple photos." For MVP we set it equal to rekognitionFaceId at
///     write time and refine later via Rekognition's SearchFaces (face-to-
///     face) clustering pass. Nullable for the same reason.
///
/// `eventId` is denormalized off Photo so we can issue collection-scoped
/// DeleteFaces calls without joining. (One Rekognition collection per event.)
///
/// Coverage screen aggregates by faceClusterId to count "photos per face."
/// Runner face search hits SearchFacesByImage → matches FaceIds → joins
/// back through this table to photoIds.
model PhotoFace {
  id                 String   @id @default(cuid())
  photoId            String
  eventId            String
  rekognitionFaceId  String?  @unique
  faceClusterId      String?
  confidence         Float    @default(0.0)
  // Bounding box in normalized [0,1] coordinates (Rekognition's native
  // format). Multiply by the preview image's width/height to draw.
  x0                 Float
  y0                 Float
  x1                 Float
  y1                 Float
  // The bib this face is geometrically linked to *within this photo* — the
  // bib whose box sits directly below this face (a runner's number is on the
  // torso, under the face). Computed at ingest from the face + bib boxes by
  // linkFacesToBibsForPhoto(); see src/lib/faceBibMatch.ts. Null when no bib
  // box is close enough below the face (or bib OCR has no box yet). This is
  // what makes per-runner face assignment robust in multi-runner frames.
  bib                Int?
  // "rekognition" | "facenet" | "manual" — same idea as PhotoBib.source.
  source             String   @default("rekognition")
  createdAt          DateTime @default(now())

  photo Photo @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@index([faceClusterId])
  @@index([photoId])
  @@index([eventId])
  @@index([eventId, bib])
}

/// One row per (photo, bib) tag. Same photo can carry several bibs (multiple
/// runners in frame); same bib can appear on many photos. `source` lets us
/// re-run detection or revoke a specific provider's results later.
model PhotoBib {
  id         String   @id @default(cuid())
  photoId    String
  bib        Int
  confidence Float    @default(1.0)
  source     String   @default("manual") // "manual" | "ocr-tesseract" | "ocr-rekognition" | "user-tag"
  // Bounding box of the detected bib number, normalized [0,1] (same space as
  // PhotoFace). Populated by OCR (Tesseract/Rekognition); null for manual /
  // user-tag rows and for rows created before box capture existed. Used to
  // link a face to the bib directly below it — see src/lib/faceBibMatch.ts.
  x0         Float?
  y0         Float?
  x1         Float?
  y1         Float?
  createdAt  DateTime @default(now())

  photo Photo @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@unique([photoId, bib])
  @@index([bib])
}

/// Order is what the buyer paid for. One row per successful PayPal capture.
///
/// Identifiers:
///   - `id` — internal cuid, used in JWT claims + relations
///   - `orderNumber` — human-readable sequential int, displayed as
///     "MK-000123" (see src/lib/orderId.ts). Stable, never changes.
///   - `paypalCaptureId` — the PayPal capture identifier; carried for
///     reconciliation with PayPal's dashboard / refund flows.
///
/// Entitlement:
///   - `photoIds[]` — snapshot of every photo this order grants access to.
///     Computed server-side at capture time (e.g. "every visible photo in
///     event X" for a bundle). Stored explicitly so future re-mint or
///     re-issue is straightforward.
///   - `downloadToken` — JWT that carries `{ orderId, photoIds }`. The
///     download API verifies this token before signing a hi-res URL.
///
/// Buyer linkage:
///   - `email` is always set (from PayPal payer if not signed-in).
///   - `userId` is set when the buyer was signed in at checkout — that
///     order shows up automatically on /runner. A guest order's userId is
///     null until we wire a back-fill flow ("claim this order" when an
///     existing user signs in later with the same email).
model Order {
  id              String    @id @default(cuid())
  orderNumber     Int       @unique @default(autoincrement())
  // Buyer linkage (always have email; userId set only when signed-in at capture)
  email           String
  userId          String?
  user            Photographer? @relation("UserOrders", fields: [userId], references: [id])
  // Bundle vs single — v0.2 ships bundle only. Single will add photoIdCovered.
  kind            String    @default("bundle")
  amount          Float
  // Event the order covers (always set for bundle; carries the scope used to
  // expand photoIds at capture time)
  eventIdCovered  String?
  photoIdCovered  String?
  // Entitlement snapshot — what the buyer can download (every id here is
  // also claimable via the downloadToken JWT)
  photoIds        String[]
  // PayPal capture id — for reconciliation with PayPal's dashboard, refunds.
  // Unique so re-capture attempts can't double-insert.
  paypalCaptureId String?   @unique
  // 30-day JWT carrying { orderId }. Minted on capture, kept on the row
  // so we can re-send the receipt email later without re-minting.
  // NO @unique — the encoded JWT is variable-length text and an index on
  // it busts the Postgres btree row-size limit; we never query by token
  // anyway (downloads supply it in the URL and we verify by signature).
  downloadToken   String?
  paidAt          DateTime  @default(now())
  createdAt       DateTime  @default(now())

  @@index([email])
  @@index([userId])
}
